{
    "version": 2,
    "framework": "nextjs",
    "installCommand": "cd ../.. && npm install",
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/_next/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/auto-checkout",
            "schedule": "30 18 * * *"
        },
        {
            "path": "/api/cron/lunch-reminder",
            "schedule": "30 7 * * 1-5"
        },
        {
            "path": "/api/cron/break-monitor",
            "schedule": "*/30 * * * *"
        }
    ],
    "regions": [
        "bom1"
    ]
}